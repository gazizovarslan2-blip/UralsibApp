<UserControl x:Class="UralSibApp.Views.DepartmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок -->
        <StackPanel Orientation="Horizontal" Margin="5">
            <Button Content="Обновить" Click="RefreshButton_Click" Width="80" Margin="2" Padding="5"
                    Background="#DA291C" Foreground="White" BorderThickness="0"/>
            <Button Content="Добавить" Click="AddButton_Click" Width="80" Margin="2" Padding="5"/>
            <Button Content="Редактировать" Click="EditButton_Click" Width="90" Margin="2" Padding="5"/>
            <Button Content="Удалить" Click="DeleteButton_Click" Width="80" Margin="2" Padding="5"/>
        </StackPanel>

        <!-- Таблица отделов -->
        <DataGrid x:Name="DepartmentsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  Margin="5" SelectionMode="Single" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9" RowHeaderWidth="0"
                  SelectionChanged="DepartmentsGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Название отдела" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Этаж" Binding="{Binding Floor}" Width="100"/>
                <DataGridTextColumn Header="Количество команд" Binding="{Binding TeamsCount}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель редактирования -->
        <Border x:Name="EditPanel" Grid.Row="2" Background="#F0F0F0" Padding="10" Margin="5" CornerRadius="5"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Название:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,5"/>
                <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>

                <TextBlock Text="Этаж:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,5"/>
                <TextBox x:Name="FloorTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5"/>

                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="OK" Click="OkButton_Click" Width="60" Margin="2" Background="#DA291C" Foreground="White" BorderThickness="0"/>
                    <Button Content="Отмена" Click="CancelButton_Click" Width="60" Margin="2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>