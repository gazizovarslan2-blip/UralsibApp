<Window x:Class="UralSibApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:UralSibApp.Views"
        Title="ОАО Уралсиб - Управление персоналом" Height="650" Width="950"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#DA291C" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <TextBlock Text="ПАО «Банк Уралсиб» — Система управления персоналом" 
                       FontSize="20" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1" Background="White" BorderBrush="#CCCCCC">
            <TabItem Header="Отделы">
                <views:DepartmentView/>
            </TabItem>
            <TabItem Header="Команды">
                <views:TeamView/>
            </TabItem>
            <TabItem Header="Сотрудники">
                <views:EmployeeView/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>